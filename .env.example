# Sao chép thành .env.local rồi điền giá trị thật (file .env.local không commit lên Git).

# Bắt buộc — Neon: Dashboard → Connection string (chế độ pooled hoặc direct tùy Neon)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Bắt buộc — chuỗi ngẫu nhiên, đủ dài (không chia sẻ công khai)
JWT_SECRET=thay-bang-chuoi-bi-mat-cua-ban

# Tùy chọn — bảo vệ cron khi không chạy qua Vercel Cron
# CRON_SECRET=

# Tùy chọn
# API_BASE_URL=http://localhost:3000
